# --- Database Configuration ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=logdb

# --- Redis Configuration ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Application Configuration ---
# Internal port is 5000, external port is configured below
DASHBOARD_PORT=5050
SECRET_KEY=GENERATE_RANDOM_SECRET

# --- Collector Configuration ---
READ_INTERVAL=1.0
LOG_PATH=/app/logs/access.log

# --- Default Admin Credentials ---
ADMIN_USER=admin
ADMIN_PASS=GENERATE_RANDOM_PASSWORD

# --- Flask Configuration ---
DEBUG=True
